FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libmagic1 \
    libmupdf-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV PYTHONPATH=/app

COPY pyproject.toml uv.lock README.md LICENSE ./
RUN pip install uv && uv sync --no-dev

COPY src/ ./src/
COPY demo/ ./demo/

EXPOSE 8000
