{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "bookkeeper-demo",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "run",
        "--with",
        "django-bookkeeper",
        "python",
        "demo/manage.py",
        "runserver",
        "8765"
      ],
      "port": 8765,
      "env": {
        "DJANGO_SETTINGS_MODULE": "demo_project.settings",
        "PYTHONPATH": "src:demo:."
      }
    }
  ]
}
